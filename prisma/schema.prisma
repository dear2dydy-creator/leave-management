generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Company {
  SKYCAMP
  SKYAN
}

enum Department {
  SALES
  SALES_SUPPORT
}

enum LeaveCategory {
  ANNUAL
  MONTHLY
  HALF
  SICK
  PUBLIC
  ABSENCE
  OTHER
}

enum LeaveOfAbsenceType {
  DEEMED    // 출근 간주: 업무상재해, 육아휴직, 출산휴가
  PERSONAL  // 개인/병가: 근속기간에서 제외
}

model Employee {
  id              String         @id @default(cuid())
  name            String
  company         Company
  department      Department
  position        String
  hireDate        DateTime
  terminationDate DateTime?
  tardyCount      Int            @default(0)
  createdAt       DateTime       @default(now())
  leaveBalances    LeaveBalance[]
  leaveRecords     LeaveRecord[]
  tardyRecords     TardyRecord[]
  leaveOfAbsences  LeaveOfAbsence[]

  @@map("employees")
}

model LeaveBalance {
  id                    String    @id @default(cuid())
  employeeId            String
  periodStart           DateTime
  periodEnd             DateTime
  allocatedDaysOverride Float?
  bonusDays             Float     @default(0)
  deductionDays         Float     @default(0)
  note                  String?
  employee              Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, periodStart])
  @@map("leave_balances")
}

model LeaveRecord {
  id              String        @id @default(cuid())
  employeeId      String
  startDate       DateTime
  endDate         DateTime
  category        LeaveCategory
  days            Float
  reason          String?
  note            String?
  isAutoGenerated Boolean       @default(false)
  createdAt       DateTime      @default(now())
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("leave_records")
}

model TardyRecord {
  id         String   @id @default(cuid())
  employeeId String
  date       DateTime
  note       String?
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("tardy_records")
}

model LeaveOfAbsence {
  id         String              @id @default(cuid())
  employeeId String
  startDate  DateTime
  endDate    DateTime
  type       LeaveOfAbsenceType
  note       String?
  createdAt  DateTime            @default(now())
  employee   Employee            @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("leave_of_absences")
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("admin_users")
}
